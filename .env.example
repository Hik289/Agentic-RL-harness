# Copy to .env and fill in your own values, then `source .env` before running scripts.

# -- LLM provider: any OpenAI-compatible chat-completions endpoint --
export OPENAI_BASE_URL="https://api.openai.com/v1"
export OPENAI_API_KEY="<your-api-key>"
export OPENAI_MODEL="gpt-5.4-mini"          # default, overrideable
# Optional pricing knobs for cost estimation:
# export OPENAI_PRICE_INPUT_PER_1M="0.25"
# export OPENAI_PRICE_OUTPUT_PER_1M="2.00"

# -- Data + results roots (default to ./data and ./results if unset) --
export AGENTICRLHARNESS_DATA="./data"
export AGENTICRLHARNESS_RESULTS="./results"
