# Copy to .env and fill in your own values, then `source .env` before running scripts.

# ── LLM provider (Azure OpenAI, v1-compatible "/openai/v1" path) ──
export AZURE_OPENAI_ENDPOINT="https://<your-resource>.services.ai.azure.com/openai/v1"
export AZURE_OPENAI_API_KEY="<your-api-key>"
export AZURE_OPENAI_DEPLOYMENT="gpt-5.4-mini"          # default, overrideable
# Optional pricing knobs for cost estimation:
# export AZURE_PRICE_INPUT_PER_1M="0.25"
# export AZURE_PRICE_OUTPUT_PER_1M="2.00"

# ── Data + results roots (default to ./data and ./results if unset) ──
export AGENTICRLHARNESS_DATA="./data"
export AGENTICRLHARNESS_RESULTS="./results"
